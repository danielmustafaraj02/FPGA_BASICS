#! /usr/bin/vvp
:ivl_version "13.0 (stable)" "(v13_0-dirty)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/ivl/system.vpi";
:vpi_module "/usr/lib/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/ivl/va_math.vpi";
S_0x55b78aec0630 .scope module, "ex3_tb" "ex3_tb" 2 1;
 .timescale 0 0;
v0x55b78aed0390_0 .var "tb_a", 0 0;
v0x55b78aed0430_0 .net "tb_y", 0 0, v0x55b78aed0270_0;  1 drivers
S_0x55b78aec07c0 .scope module, "uut" "ex3" 2 5, 3 1 0, S_0x55b78aec0630;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /OUTPUT 1 "y";
v0x55b78aec0a10_0 .net "a", 0 0, v0x55b78aed0390_0;  1 drivers
v0x55b78aed0270_0 .var "y", 0 0;
E_0x55b78aec0ba0 .event anyedge, v0x55b78aec0a10_0;
    .scope S_0x55b78aec07c0;
T_0 ;
    %wait E_0x55b78aec0ba0;
    %load/vec4 v0x55b78aec0a10_0;
    %store/vec4 v0x55b78aed0270_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x55b78aec0630;
T_1 ;
    %vpi_call 2 11 "$dumpfile", "test.vcd" {0 0 0};
    %vpi_call 2 12 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x55b78aec0630 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55b78aed0390_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55b78aed0390_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 20 "$finish" {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "Exercise3_tb.v";
    "Exercise3.v";
