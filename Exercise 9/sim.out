#! /usr/bin/vvp
:ivl_version "13.0 (stable)" "(v13_0-dirty)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/ivl/system.vpi";
:vpi_module "/usr/lib/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/ivl/va_math.vpi";
S_0x557f13d8ded0 .scope module, "ex9_tb" "ex9_tb" 2 3;
 .timescale -9 -12;
v0x557f13da0380_0 .var "clk", 0 0;
v0x557f13da0420_0 .net "q", 3 0, v0x557f13da0180_0;  1 drivers
v0x557f13da04f0_0 .var "reset", 0 0;
S_0x557f13d8e060 .scope module, "uut" "ex8" 2 8, 3 11 0, S_0x557f13d8ded0;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "reset";
    .port_info 2 /OUTPUT 4 "q";
v0x557f13d8e2b0_0 .net "clk", 0 0, v0x557f13da0380_0;  1 drivers
v0x557f13da0180_0 .var "q", 3 0;
v0x557f13da0260_0 .net "reset", 0 0, v0x557f13da04f0_0;  1 drivers
E_0x557f13d8ea30 .event posedge, v0x557f13d8e2b0_0;
    .scope S_0x557f13d8e060;
T_0 ;
    %wait E_0x557f13d8ea30;
    %load/vec4 v0x557f13da0260_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 4;
    %assign/vec4 v0x557f13da0180_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x557f13da0180_0;
    %addi 1, 0, 4;
    %assign/vec4 v0x557f13da0180_0, 0;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x557f13d8ded0;
T_1 ;
    %delay 5000, 0;
    %load/vec4 v0x557f13da0380_0;
    %inv;
    %store/vec4 v0x557f13da0380_0, 0, 1;
    %jmp T_1;
    .thread T_1;
    .scope S_0x557f13d8ded0;
T_2 ;
    %vpi_call 2 17 "$monitor", "At time %t: reset=%b, count=%d (%b)", $time, v0x557f13da04f0_0, v0x557f13da0420_0, v0x557f13da0420_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x557f13da0380_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x557f13da04f0_0, 0, 1;
    %delay 20000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x557f13da04f0_0, 0, 1;
    %delay 200000, 0;
    %vpi_call 2 24 "$display", "Simulation Complete." {0 0 0};
    %vpi_call 2 26 "$finish" {0 0 0};
    %end;
    .thread T_2;
